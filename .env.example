# local-context environment variables
# Copy this file to .env and edit. The server explicitly loads repo-root .env
# so MCP clients work even when they start the stdio server from another cwd.
#
#   cp .env.example .env

# ----------------------------------------------------------------------
# Model endpoint
# ----------------------------------------------------------------------
# Any OpenAI-compatible /v1/chat/completions URL. The defaults below are
# for Ollama because it is the easiest to get started with. For raw
# performance, switch to llama.cpp llama-server (see README).
#
#   Ollama (default)           http://127.0.0.1:11434/v1
#   llama.cpp llama-server     http://127.0.0.1:8088/v1
#   LM Studio                  http://127.0.0.1:1234/v1
#   vLLM                       http://127.0.0.1:8000/v1
MODEL_ENDPOINT=http://127.0.0.1:11434/v1

# The model name your endpoint serves. There is intentionally no fallback
# default in code because it depends entirely on which backend you are
# running. Examples:
#   Ollama        e.g. qwen3:8b   (after `ollama pull qwen3:8b`)
#   llama.cpp     whatever you passed to --alias, e.g. my-local-model
#   LM Studio     the loaded model name shown in the UI
#   vLLM          the served model name
LOCAL_CONTEXT_MODEL=qwen3:8b

# ----------------------------------------------------------------------
# Optional: where the version-pinned upstream clones live
# ----------------------------------------------------------------------
# Defaults to <repo>/repos
# LOCAL_CONTEXT_REPOS_DIR=/var/cache/local-context/repos

# ----------------------------------------------------------------------
# Optional: web_search tool
# ----------------------------------------------------------------------
# Set one of these to enable the web_search tool. Tavily wins if both
# are set. Without either, the agent can still answer from the cloned
# source, it just cannot reach the live web.
# TAVILY_API_KEY=
# EXA_API_KEY=
